  `;
  document.getElementById('modal-footer').innerHTML = `
    <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="salvarImovel('${id || ''}')">Salvar imóvel</button>
  `;
  toggleFinanciamento();
  openModal();
}

function toggleFinanciamento() {
  const tipo = document.getElementById('f-fin-tipo')?.value;
  const ids = ['f-credor-wrap','f-entrada-wrap','f-saldo-wrap','f-taxa-wrap','f-prazo-wrap','f-sistema-wrap','f-inicio-wrap'];
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('hidden', tipo === 'nenhum');
  });
}

function salvarImovel(id) {
  const nome = document.getElementById('f-nome').value.trim();
  if (!nome) { alert('Informe o nome do imóvel'); return; }
  const finTipo = document.getElementById('f-fin-tipo').value;
  const financiamento = finTipo === 'nenhum' ? null : {
    tipo: finTipo,
    credor: document.getElementById('f-credor').value,
    entrada: parseFloat(document.getElementById('f-entrada').value) || 0,
    saldoDevedor: parseFloat(document.getElementById('f-saldo').value) || 0,
    taxaJurosAnual: parseFloat(document.getElementById('f-taxa').value) || 0,
    taxaJurosMensal: (parseFloat(document.getElementById('f-taxa').value) || 0) / 12,
    prazoMeses: parseInt(document.getElementById('f-prazo').value) || 0,
    sistema: document.getElementById('f-sistema').value,
    dataInicio: document.getElementById('f-inicio').value,
  };
  const obj = {
    id: id || Date.now().toString(),
    nome,
    empreendimento: document.getElementById('f-empreendimento').value,
    tipo: document.getElementById('f-tipo').value,
    dataAquisicao: document.getElementById('f-data').value,
    precoAquisicao: parseFloat(document.getElementById('f-preco').value) || 0,
    valorMercado: parseFloat(document.getElementById('f-vm').value) || 0,
    obs: document.getElementById('f-obs').value,
    financiamento
  };
  if (id) {
    const idx = state.imoveis.findIndex(i => i.id === id);
    if (idx >= 0) state.imoveis[idx] = obj;
  } else {
    state.imoveis.push(obj);
  }
  save();
  closeModal();
  renderImoveis();
}

function deletarImovel(id) {
  if (!confirm('Excluir este imóvel? Todos os lançamentos associados também serão removidos.')) return;
  state.imoveis = state.imoveis.filter(i => i.id !== id);
  state.lancamentos = state.lancamentos.filter(l => l.imovelId !== id);
  save();
  renderImoveis();
}

// ─── FINANCIAMENTO ────────────────────────────────────────────────────────────
function renderFinanciamento() {
  document.getElementById('topbar-actions').innerHTML = '';
  const c = document.getElementById('content');
  const financiados = state.imoveis.filter(im => im.financiamento);
  if (financiados.length === 0) {
    c.innerHTML = `<div class="card"><div class="empty"><div class="empty-icon">💳</div><h3>Nenhum imóvel financiado</h3><p>Cadastre um imóvel com financiamento para ver a amortização.</p><button class="btn btn-primary" onclick="showPage('imoveis')">Ir para imóveis</button></div></div>`;
    return;
  }

  let html = '';
  financiados.forEach(im => {
    const fin = im.financiamento;
    const taxaM = fin.taxaJurosMensal || fin.taxaJurosAnual / 12;
    const amort = gerarAmortizacao(im);
    const totalParcelas = amort.reduce((s, r) => s + r.parcela, 0);
    const totalJuros = amort.reduce((s, r) => s + r.juros, 0);
    const saldoHoje = calcSaldoAtual(im);
    const primeiraParc = amort[0];

    html += `<div class="card mb-16">
      <div class="card-header">
        <span class="card-title">${im.nome}</span>
        <span class="tag tag-info">${fin.tipo === 'banco' ? fin.credor || 'Banco' : 'Construtora'} · ${fin.sistema}</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px">
        <div><div class="metric-label">Saldo devedor inicial</div><div class="fw-600 text-mono">${fmtBRL(fin.saldoDevedor)}</div></div>
        <div><div class="metric-label">Saldo hoje (estimado)</div><div class="fw-600 text-mono color-danger">${fmtBRL(saldoHoje)}</div></div>
        <div><div class="metric-label">Taxa de juros</div><div class="fw-600 text-mono">${fmtPct(fin.taxaJurosAnual)} a.a. / ${fmtPct(taxaM, 3)} a.m.</div></div>
        <div><div class="metric-label">Prazo restante</div><div class="fw-600 text-mono">${fin.prazoMeses} meses</div></div>
        <div><div class="metric-label">1ª parcela (${fin.sistema})</div><div class="fw-600 text-mono">${fmtBRL(primeiraParc?.parcela)}</div></div>
        <div><div class="metric-label">Total de parcelas</div><div class="fw-600 text-mono">${fmtBRL(totalParcelas)}</div></div>
        <div><div class="metric-label">Total de juros</div><div class="fw-600 text-mono color-danger">${fmtBRL(totalJuros)}</div></div>
        <div><div class="metric-label">Custo efetivo total</div><div class="fw-600 text-mono">${fmtBRL(fin.entrada + totalParcelas)}</div></div>
      </div>
      <div class="section-title">Tabela de amortização (primeiros 24 meses)</div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Mês</th><th class="td-right">Parcela</th><th class="td-right">Amortização</th><th class="td-right">Juros</th><th class="td-right">Saldo devedor</th></tr></thead>
          <tbody>
            ${amort.slice(0, 24).map(r => `<tr>
              <td>${r.mes}</td>
              <td class="td-right td-mono">${fmtBRL(r.parcela)}</td>
              <td class="td-right td-mono color-success">${fmtBRL(r.amort)}</td>
              <td class="td-right td-mono color-danger">${fmtBRL(r.juros)}</td>
              <td class="td-right td-mono">${fmtBRL(r.saldo)}</td>
            </tr>`).join('')}
          </tbody>
        </table>
      </div>
      ${amort.length > 24 ? `<div style="text-align:center;padding:12px;font-size:12px;color:var(--text3)">Exibindo 24 de ${amort.length} meses</div>` : ''}
    </div>`;
  });

  c.innerHTML = html;
}

// ─── FLUXO DE CAIXA ───────────────────────────────────────────────────────────
function renderFluxo() {
  const mesAtual = new Date().toISOString().slice(0, 7);
  document.getElementById('topbar-actions').innerHTML = `
    <input type="month" id="mes-filtro" value="${mesAtual}" onchange="renderFluxo()" style="padding:6px 10px;border:1px solid var(--border2);border-radius:var(--radius-sm);font-size:13px;background:var(--surface)">
    <button class="btn btn-primary btn-sm" onclick="openModalLancamento()">+ Lançamento</button>`;

  const mes = document.getElementById('mes-filtro')?.value || mesAtual;
  const lancMes = (state.lancamentos || []).filter(l => l.mes === mes);
  const entradas = lancMes.filter(l => l.tipo === 'entrada');
  const saidas = lancMes.filter(l => l.tipo === 'saida');
  const totalEnt = entradas.reduce((s, l) => s + l.valor, 0);
  const totalSai = saidas.reduce((s, l) => s + l.valor, 0);
  const saldo = totalEnt - totalSai;

  const c = document.getElementById('content');
  c.innerHTML = `
    <div class="metrics-grid">
      <div class="metric-card"><div class="metric-label">Entradas</div><div class="metric-value metric-pos">${fmtBRL(totalEnt)}</div></div>
      <div class="metric-card"><div class="metric-label">Saídas</div><div class="metric-value metric-neg">${fmtBRL(totalSai)}</div></div>
      <div class="metric-card"><div class="metric-label">Saldo do mês</div><div class="metric-value ${saldo >= 0 ? 'metric-pos' : 'metric-neg'}">${fmtBRL(saldo)}</div></div>
      <div class="metric-card"><div class="metric-label">Lançamentos</div><div class="metric-value">${lancMes.length}</div></div>
    </div>
    <div class="two-col">
      <div class="card">
        <div class="card-header"><span class="card-title">Entradas</span><button class="btn btn-ghost btn-sm" onclick="openModalLancamento('entrada')">+ Adicionar</button></div>
        ${entradas.length === 0 ? `<div style="text-align:center;padding:30px;color:var(--text3);font-size:13px">Nenhuma entrada neste mês</div>` :
          `<table><thead><tr><th>Descrição</th><th>Imóvel</th><th class="td-right">Valor</th><th></th></tr></thead><tbody>
          ${entradas.map(l => `<tr>
            <td>${l.descricao}</td>
            <td><span style="font-size:11px;color:var(--text3)">${state.imoveis.find(i => i.id === l.imovelId)?.nome || '—'}</span></td>
            <td class="td-right td-mono color-success">${fmtBRL(l.valor)}</td>
            <td><button class="btn btn-ghost btn-sm" onclick="deletarLancamento('${l.id}')">✕</button></td>
          </tr>`).join('')}
          </tbody></table>`}
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Saídas</span><button class="btn btn-ghost btn-sm" onclick="openModalLancamento('saida')">+ Adicionar</button></div>
        ${saidas.length === 0 ? `<div style="text-align:center;padding:30px;color:var(--text3);font-size:13px">Nenhuma saída neste mês</div>` :
          `<table><thead><tr><th>Descrição</th><th>Imóvel</th><th class="td-right">Valor</th><th></th></tr></thead><tbody>
          ${saidas.map(l => `<tr>
            <td>${l.descricao}</td>
            <td><span style="font-size:11px;color:var(--text3)">${state.imoveis.find(i => i.id === l.imovelId)?.nome || '—'}</span></td>
            <td class="td-right td-mono color-danger">${fmtBRL(l.valor)}</td>
            <td><button class="btn btn-ghost btn-sm" onclick="deletarLancamento('${l.id}')">✕</button></td>
          </tr>`).join('')}
          </tbody></table>`}
      </div>
    </div>`;
}

function openModalLancamento(tipoDefault) {
  const mes = document.getElementById('mes-filtro')?.value || new Date().toISOString().slice(0, 7);
  document.getElementById('modal-title').textContent = 'Novo lançamento';
  document.getElementById('modal-body').innerHTML = `
    <div class="form-grid">
      <div class="form-group">
        <label>Tipo</label>
        <select id="l-tipo">
          <option value="saida" ${tipoDefault === 'saida' ? 'selected' : ''}>Saída (despesa / parcela)</option>
          <option value="entrada" ${tipoDefault === 'entrada' ? 'selected' : ''}>Entrada (aluguel / receita)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Mês de referência</label>
        <input type="month" id="l-mes" value="${mes}">
      </div>
      <div class="form-group form-full">
        <label>Descrição</label>
        <input id="l-desc" placeholder="Ex: Parcela mensal, Condomínio, IPTU...">
      </div>
      <div class="form-group">
        <label>Valor (R$)</label>
        <input id="l-valor" placeholder="Ex: 4200">
      </div>
      <div class="form-group">
        <label>Imóvel relacionado</label>
        <select id="l-imovel">
          <option value="">— Nenhum específico —</option>
          ${state.imoveis.map(im => `<option value="${im.id}">${im.nome}</option>`).join('')}
        </select>
      </div>
    </div>`;
  document.getElementById('modal-footer').innerHTML = `
    <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="salvarLancamento()">Salvar lançamento</button>`;
  openModal();
}

function salvarLancamento() {
  const desc = document.getElementById('l-desc').value.trim();
  const valor = parseFloat(document.getElementById('l-valor').value);
  if (!desc || !valor) { alert('Preencha descrição e valor'); return; }
  state.lancamentos = state.lancamentos || [];
  state.lancamentos.push({
    id: Date.now().toString(),
    tipo: document.getElementById('l-tipo').value,
    mes: document.getElementById('l-mes').value,
    descricao: desc,
    valor,
    imovelId: document.getElementById('l-imovel').value
  });
  save();
  closeModal();
  renderFluxo();
}

function deletarLancamento(id) {
  state.lancamentos = state.lancamentos.filter(l => l.id !== id);
  save();
  renderFluxo();
}

// ─── ANÁLISE ──────────────────────────────────────────────────────────────────
function renderAnalise() {
  document.getElementById('topbar-actions').innerHTML = '';
  const c = document.getElementById('content');

  if (state.imoveis.length === 0) {
    c.innerHTML = `<div class="card"><div class="empty"><div class="empty-icon">📊</div><h3>Sem imóveis para analisar</h3><button class="btn btn-primary" onclick="showPage('imoveis')">Cadastrar imóvel</button></div></div>`;
    return;
  }

  let html = `<div class="alert alert-info">Selecione um imóvel e o horizonte de tempo para ver a análise de viabilidade da venda.</div>
  <div class="card mb-16">
    <div class="form-grid form-grid-3">
      <div class="form-group">
        <label>Imóvel</label>
        <select id="an-imovel" onchange="calcularAnalise()">
          ${state.imoveis.map(im => `<option value="${im.id}">${im.nome}</option>`).join('')}
        </select>
      </div>
      <div class="form-group">
        <label>Vender em (anos)</label>
        <select id="an-anos" onchange="calcularAnalise()">
          ${[1,2,3,5,7,10,15,20].map(a => `<option value="${a}" ${a === 5 ? 'selected' : ''}>${a} ano${a > 1 ? 's' : ''}</option>`).join('')}
        </select>
      </div>
      <div class="form-group">
        <label>Valorização anual estimada (%)</label>
        <input id="an-val" type="number" step="0.5" value="8" onchange="calcularAnalise()" placeholder="Ex: 8">
      </div>
    </div>
  </div>
  <div id="analise-resultado"></div>`;

  c.innerHTML = html;
  calcularAnalise();
}

function calcularAnalise() {
  const imId = document.getElementById('an-imovel')?.value;
  const anos = parseInt(document.getElementById('an-anos')?.value) || 5;
  const valorAnual = parseFloat(document.getElementById('an-val')?.value) || 0;
  const im = state.imoveis.find(i => i.id === imId);
  if (!im) return;

  const vm = im.valorMercado || im.precoAquisicao || 0;
  const valorFuturo = vm * Math.pow(1 + valorAnual / 100, anos);
  const dataVenda = new Date();
  dataVenda.setFullYear(dataVenda.getFullYear() + anos);

  const { totalJuros, totalParcelas } = calcTotalJurosPagos(im, dataVenda.toISOString());
  const amort = gerarAmortizacao(im);
  const mesIdx = Math.min(anos * 12, amort.length) - 1;
  const saldoNaVenda = mesIdx >= 0 ? Math.max(0, amort[mesIdx]?.saldo || 0) : 0;

  const aqs = im.precoAquisicao || 0;
  const entrada = im.financiamento?.entrada || 0;
  const despesas = (state.lancamentos || [])
    .filter(l => l.imovelId === im.id && l.tipo === 'saida')
    .reduce((s, l) => s + l.valor, 0);

  const custoTotal = aqs + totalParcelas + despesas;
  const receitaLiquida = valorFuturo - saldoNaVenda;
  const lucro = receitaLiquida - custoTotal;
  const roi = custoTotal > 0 ? (lucro / custoTotal) * 100 : 0;
  const roiAnual = Math.pow(1 + roi / 100, 1 / anos) - 1;

  const valMin = calcValorizacaoMinima(im, anos);

  const res = document.getElementById('analise-resultado');
  if (!res) return;
  res.innerHTML = `
    <div class="two-col">
      <div class="card">
        <div class="card-title" style="margin-bottom:16px">Projeção de venda em ${anos} ano${anos > 1 ? 's' : ''}</div>
        <div style="display:flex;flex-direction:column;gap:12px">
          <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
            <span class="color-muted">Valor atual de mercado</span><span class="fw-600 text-mono">${fmtBRL(vm)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
            <span class="color-muted">Valor futuro estimado (${valorAnual}%/a.a.)</span><span class="fw-600 text-mono">${fmtBRL(valorFuturo)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
            <span class="color-muted">(-) Saldo devedor na venda</span><span class="fw-600 text-mono color-danger">- ${fmtBRL(saldoNaVenda)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
            <span class="color-muted">Receita líquida da venda</span><span class="fw-600 text-mono">${fmtBRL(receitaLiquida)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
            <span class="color-muted">(-) Custo total acumulado</span><span class="fw-600 text-mono color-danger">- ${fmtBRL(custoTotal)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:12px;background:${lucro >= 0 ? 'var(--success-light)' : 'var(--danger-light)'};border-radius:var(--radius-sm)">
            <span style="font-weight:600;color:${lucro >= 0 ? 'var(--success)' : 'var(--danger)'}">Lucro / Prejuízo</span>
            <span style="font-weight:700;font-family:var(--mono);font-size:16px;color:${lucro >= 0 ? 'var(--success)' : 'var(--danger)'}">${fmtBRL(lucro)}</span>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:16px">Indicadores do investimento</div>
        <div style="display:flex;flex-direction:column;gap:14px">
          <div>
            <div class="metric-label">ROI total no período</div>
            <div class="metric-value ${roi >= 0 ? 'metric-pos' : 'metric-neg'}">${fmtPct(roi)}</div>
          </div>
          <div>
            <div class="metric-label">ROI anualizado</div>
            <div class="metric-value ${roiAnual >= 0 ? 'metric-pos' : 'metric-neg'}">${fmtPct(roiAnual * 100)}/a.a.</div>
          </div>
          <div>
            <div class="metric-label">Total de juros pagos</div>
            <div class="metric-value metric-neg">${fmtBRL(totalJuros)}</div>
          </div>
          <div class="divider"></div>
          <div>
            <div class="metric-label">Valorização mínima para ponto de equilíbrio</div>
            <div class="metric-value ${valMin && valMin > 12 ? 'metric-neg' : valMin && valMin > 8 ? 'metric-warn' : 'metric-pos'}">${valMin !== null ? '+' + fmtPct(valMin) + '/a.a.' : 'Quitado'}</div>
            <div class="metric-sub">abaixo disso o investimento dá prejuízo</div>
          </div>
          <div class="${valorAnual >= (valMin || 0) ? 'alert alert-info' : 'alert alert-warn'}" style="margin-bottom:0">
            ${valorAnual >= (valMin || 0)
              ? `Com ${valorAnual}%/a.a. de valorização, o investimento é lucrativo.`
              : `Com ${valorAnual}%/a.a., o imóvel não cobre o custo do financiamento. Precisa de pelo menos ${fmtPct(valMin || 0)}/a.a.`}
          </div>
        </div>
      </div>
    </div>`;
}

// ─── CONFIG ───────────────────────────────────────────────────────────────────
function renderConfig() {
  document.getElementById('topbar-actions').innerHTML = '';
  const c = document.getElementById('content');
  c.innerHTML = `
    <div style="max-width:560px">
      <div class="card mb-16">
        <div class="card-title" style="margin-bottom:16px">Sincronização com GitHub Gist</div>
        <div class="alert alert-info">Os dados são salvos no seu navegador automaticamente. Configure o Gist para acessar de qualquer computador.</div>
        <div class="form-grid" style="margin-top:16px">
          <div class="form-group form-full">
            <label>Personal Access Token do GitHub</label>
            <input id="cfg-token" type="password" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" value="${state.gistToken || ''}">
            <span class="form-hint">Gere em: GitHub → Settings → Developer settings → Personal access tokens → New token (scope: gist)</span>
          </div>
          <div class="form-group form-full">
            <label>ID do Gist <span style="color:var(--text3)">(deixe em branco para criar um novo)</span></label>
            <input id="cfg-gist" placeholder="Será preenchido automaticamente" value="${state.gistId || ''}">
          </div>
        </div>
        <div style="display:flex;gap:8px;margin-top:16px">
          <button class="btn btn-primary" onclick="salvarConfig()">Conectar e sincronizar</button>
          ${state.gistId ? `<button class="btn btn-secondary" onclick="carregarGist()">Carregar dados do Gist</button>` : ''}
        </div>
        <div id="cfg-msg" style="margin-top:12px;font-size:13px"></div>
      </div>

      <div class="card mb-16">
        <div class="card-title" style="margin-bottom:16px">Dados locais</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:12px">
          ${state.imoveis.length} imóve${state.imoveis.length !== 1 ? 'is' : 'l'} · ${(state.lancamentos || []).length} lançamentos salvos localmente
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn btn-secondary btn-sm" onclick="exportarJSON()">Exportar JSON</button>
          <button class="btn btn-danger btn-sm" onclick="limparDados()">Limpar todos os dados</button>
        </div>
      </div>
    </div>`;
}

async function salvarConfig() {
  const token = document.getElementById('cfg-token').value.trim();
  const gistId = document.getElementById('cfg-gist').value.trim();
  const msg = document.getElementById('cfg-msg');
  if (!token) { msg.textContent = 'Informe o token.'; msg.style.color = 'var(--danger)'; return; }

  msg.textContent = 'Conectando...'; msg.style.color = 'var(--text2)';
  try {
    let id = gistId;
    if (!id) {
      id = await createGist(token);
      msg.textContent = `Gist criado! ID: ${id}`;
    }
    state.gistToken = token;
    state.gistId = id;
    saveLocal();
    await saveGist();
    msg.textContent = '✓ Conectado e sincronizado com sucesso!';
    msg.style.color = 'var(--success)';
    updateGistStatus();
    renderConfig();
  } catch(e) {
    msg.textContent = 'Erro: ' + e.message;
    msg.style.color = 'var(--danger)';
  }
}

async function carregarGist() {
  const msg = document.getElementById('cfg-msg');
  msg.textContent = 'Carregando...'; msg.style.color = 'var(--text2)';
  const ok = await loadGist();
  if (ok) { msg.textContent = '✓ Dados carregados!'; msg.style.color = 'var(--success)'; renderConfig(); }
  else { msg.textContent = 'Erro ao carregar. Verifique o token e o ID.'; msg.style.color = 'var(--danger)'; }
}

function exportarJSON() {
  const data = JSON.stringify({ imoveis: state.imoveis, lancamentos: state.lancamentos }, null, 2);
  const a = document.createElement('a');
  a.href = 'data:application/json,' + encodeURIComponent(data);
  a.download = 'patrimonio_imoveis.json';
  a.click();
}

function limparDados() {
  if (!confirm('Limpar TODOS os dados? Esta ação não pode ser desfeita.')) return;
  state.imoveis = []; state.lancamentos = [];
  save(); renderConfig();
}

// ─── MODAL ────────────────────────────────────────────────────────────────────
function openModal() { document.getElementById('modal-overlay').classList.remove('hidden'); }
function closeModal() { document.getElementById('modal-overlay').classList.add('hidden'); }
function closeModalOnOverlay(e) { if (e.target === document.getElementById('modal-overlay')) closeModal(); }

// ─── INIT ─────────────────────────────────────────────────────────────────────
loadLocal();
updateGistStatus();
showPage('dashboard');
</script>
</body>
</html>
