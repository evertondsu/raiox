  document.getElementById('modal-body').innerHTML = `
    <div class="form-grid">
      <div class="form-group form-full">
        <label>Nome do imóvel / unidade</label>
        <input id="f-nome" placeholder="Ex: Apt 304 — Ed. Reserva" value="${im?.nome || ''}">
      </div>
      <div class="form-group">
        <label>Empreendimento / prédio</label>
        <input id="f-empreendimento" placeholder="Ex: Ed. Reserva Verde" value="${im?.empreendimento || ''}">
      </div>
      <div class="form-group">
        <label>Tipo</label>
        <select id="f-tipo">
          <option value="Apartamento" ${im?.tipo === 'Apartamento' ? 'selected' : ''}>Apartamento</option>
          <option value="Casa" ${im?.tipo === 'Casa' ? 'selected' : ''}>Casa</option>
          <option value="Sala comercial" ${im?.tipo === 'Sala comercial' ? 'selected' : ''}>Sala comercial</option>
          <option value="Studio" ${im?.tipo === 'Studio' ? 'selected' : ''}>Studio</option>
          <option value="Terreno" ${im?.tipo === 'Terreno' ? 'selected' : ''}>Terreno</option>
          <option value="Outro" ${im?.tipo === 'Outro' ? 'selected' : ''}>Outro</option>
        </select>
      </div>
      <div class="form-group">
        <label>Data de aquisição</label>
        <input type="month" id="f-data" value="${im?.dataAquisicao || ''}">
      </div>
      <div class="form-group">
        <label>Preço de aquisição (R$)</label>
        <input id="f-preco" placeholder="Ex: 450000" value="${im?.precoAquisicao || ''}">
      </div>
      <div class="form-group">
        <label>Valor de mercado atual (R$)</label>
        <input id="f-vm" placeholder="Ex: 520000" value="${im?.valorMercado || ''}">
        <span class="form-hint">Atualize manualmente quando quiser</span>
      </div>
      <div class="form-group form-full">
        <label>Observações</label>
        <textarea id="f-obs" rows="2" placeholder="Localização, características, etc.">${im?.obs || ''}</textarea>
      </div>
    </div>
    <div class="divider"></div>
    <div class="section-title">Financiamento</div>
    <div class="form-grid">
      <div class="form-group">
        <label>Tipo de financiamento</label>
        <select id="f-fin-tipo" onchange="toggleFinanciamento()">
          <option value="nenhum" ${!im?.financiamento ? 'selected' : ''}>Sem financiamento / quitado</option>
          <option value="banco" ${im?.financiamento?.tipo === 'banco' ? 'selected' : ''}>Banco (ex: Caixa, Itaú)</option>
          <option value="construtora" ${im?.financiamento?.tipo === 'construtora' ? 'selected' : ''}>Construtora / incorporadora</option>
        </select>
      </div>
      <div class="form-group" id="f-credor-wrap">
        <label>Credor</label>
        <input id="f-credor" placeholder="Ex: Caixa Econômica Federal" value="${im?.financiamento?.credor || ''}">
      </div>
      <div class="form-group" id="f-entrada-wrap">
        <label>Valor de entrada (R$)</label>
        <input id="f-entrada" placeholder="Ex: 80000" value="${im?.financiamento?.entrada || ''}">
      </div>
      <div class="form-group" id="f-saldo-wrap">
        <label>Saldo devedor atual (R$)</label>
        <input id="f-saldo" placeholder="Ex: 370000" value="${im?.financiamento?.saldoDevedor || ''}">
      </div>
      <div class="form-group" id="f-taxa-wrap">
        <label>Taxa de juros anual (%)</label>
        <input id="f-taxa" placeholder="Ex: 8.5" value="${im?.financiamento?.taxaJurosAnual || ''}">
      </div>
      <div class="form-group" id="f-prazo-wrap">
        <label>Prazo restante (meses)</label>
        <input id="f-prazo" placeholder="Ex: 240" value="${im?.financiamento?.prazoMeses || ''}">
      </div>
      <div class="form-group" id="f-sistema-wrap">
        <label>Sistema de amortização</label>
        <select id="f-sistema">
          <option value="SAC" ${im?.financiamento?.sistema === 'SAC' ? 'selected' : ''}>SAC (parcelas decrescentes)</option>
          <option value="PRICE" ${im?.financiamento?.sistema === 'PRICE' ? 'selected' : ''}>PRICE (parcelas fixas)</option>
        </select>
      </div>
      <div class="form-group" id="f-inicio-wrap">
        <label>Data de início do financiamento</label>
        <input type="month" id="f-inicio" value="${im?.financiamento?.dataInicio || ''}">
