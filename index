<script>
// ─── STATE ───────────────────────────────────────────────────────────────────
let state = {
  imoveis: [],
  lancamentos: [],
  gistToken: '',
  gistId: '',
  currentPage: 'dashboard'
};

// ─── PERSISTENCE ─────────────────────────────────────────────────────────────
function saveLocal() {
  localStorage.setItem('patrimonio_state', JSON.stringify(state));
}

function loadLocal() {
  const s = localStorage.getItem('patrimonio_state');
  if (s) {
    try { state = { ...state, ...JSON.parse(s) }; } catch(e) {}
  }
}

async function saveGist() {
  if (!state.gistToken || !state.gistId) return;
  const data = { imoveis: state.imoveis, lancamentos: state.lancamentos };
  try {
    await fetch(`https://api.github.com/gists/${state.gistId}`, {
      method: 'PATCH',
      headers: { Authorization: `token ${state.gistToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ files: { 'patrimonio.json': { content: JSON.stringify(data, null, 2) } } })
    });
  } catch(e) { console.error('Gist save error', e); }
}

async function loadGist() {
  if (!state.gistToken || !state.gistId) return false;
  try {
    const r = await fetch(`https://api.github.com/gists/${state.gistId}`, {
      headers: { Authorization: `token ${state.gistToken}` }
    });
    if (!r.ok) return false;
    const gist = await r.json();
    const content = gist.files['patrimonio.json']?.content;
    if (content) {
      const data = JSON.parse(content);
      state.imoveis = data.imoveis || [];
      state.lancamentos = data.lancamentos || [];
      saveLocal();
    }
    return true;
  } catch(e) { return false; }
}

async function createGist(token) {
  const r = await fetch('https://api.github.com/gists', {
    method: 'POST',
    headers: { Authorization: `token ${token}`, 'Content-Type': 'application/json' },
    body: JSON.stringify({
      description: 'Patrimônio Imobiliário - dados privados',
      public: false,
      files: { 'patrimonio.json': { content: JSON.stringify({ imoveis: [], lancamentos: [] }, null, 2) } }
    })
  });
  if (!r.ok) throw new Error('Token inválido ou sem permissão');
  const gist = await r.json();
  return gist.id;
}

function updateGistStatus() {
  const dot = document.getElementById('gist-dot');
  const txt = document.getElementById('gist-status-text');
  if (state.gistToken && state.gistId) {
    dot.classList.remove('off');
    txt.textContent = 'Gist conectado';
  } else {
    dot.classList.add('off');
    txt.textContent = 'Gist desconectado';
  }
}

// ─── SAVE (local + gist) ─────────────────────────────────────────────────────
function save() {
  saveLocal();
  saveGist();
}

// ─── FORMATTERS ──────────────────────────────────────────────────────────────
function fmtBRL(n) {
  if (n == null || isNaN(n)) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 }).format(n);
}
function fmtPct(n, decimals = 1) {
  if (n == null || isNaN(n)) return '—';
  return n.toFixed(decimals) + '%';
}
function parseBRL(s) {
  if (!s) return 0;
  return parseFloat(s.toString().replace(/[^\d,.-]/g, '').replace(',', '.')) || 0;
}
function fmtDate(d) {
  if (!d) return '—';
  const [y, m] = d.split('-');
  return `${m}/${y}`;
}
function monthsBetween(d1, d2) {
  const a = new Date(d1), b = new Date(d2);
  return (b.getFullYear() - a.getFullYear()) * 12 + (b.getMonth() - a.getMonth());
}

// ─── FINANCE CALCS ───────────────────────────────────────────────────────────
function calcParcelaSAC(saldo, taxaMensal, prazoMeses) {
  const amort = saldo / prazoMeses;
  const juros = saldo * taxaMensal;
  return { parcela: amort + juros, amort, juros };
}

function calcParcelaPrice(saldo, taxaMensal, prazoMeses) {
  if (taxaMensal === 0) return { parcela: saldo / prazoMeses, amort: saldo / prazoMeses, juros: 0 };
  const p = saldo * (taxaMensal * Math.pow(1 + taxaMensal, prazoMeses)) / (Math.pow(1 + taxaMensal, prazoMeses) - 1);
  return { parcela: p, amort: p - saldo * taxaMensal, juros: saldo * taxaMensal };
}

function gerarAmortizacao(imovel) {
  if (!imovel.financiamento) return [];
  const { saldoDevedor, taxaJurosMensal, prazoMeses, sistema } = imovel.financiamento;
  const rows = [];
  let saldo = saldoDevedor;
  for (let i = 1; i <= prazoMeses; i++) {
    const { parcela, amort, juros } = sistema === 'SAC'
      ? calcParcelaSAC(saldo, taxaJurosMensal / 100, prazoMeses - i + 1)
      : calcParcelaPrice(saldo, taxaJurosMensal / 100, prazoMeses - i + 1);
    rows.push({ mes: i, parcela, amort, juros, saldo });
    saldo -= amort;
    if (saldo < 0) saldo = 0;
  }
  return rows;
}

function calcTotalJurosPagos(imovel, ateData) {
  const rows = gerarAmortizacao(imovel);
  const inicio = new Date(imovel.financiamento?.dataInicio || imovel.dataAquisicao);
  const ate = new Date(ateData || new Date());
  let totalJuros = 0;
  let totalParcelas = 0;
  rows.forEach((r, i) => {
    const d = new Date(inicio);
    d.setMonth(d.getMonth() + i);
    if (d <= ate) {
      totalJuros += r.juros;
      totalParcelas += r.parcela;
    }
  });
  return { totalJuros, totalParcelas };
}

function calcSaldoAtual(imovel) {
  const rows = gerarAmortizacao(imovel);
  const inicio = new Date(imovel.financiamento?.dataInicio || imovel.dataAquisicao);
  const hoje = new Date();
  let saldo = imovel.financiamento?.saldoDevedor || 0;
  rows.forEach((r, i) => {
    const d = new Date(inicio);
    d.setMonth(d.getMonth() + i);
    if (d <= hoje) saldo = Math.max(0, saldo - r.amort);
  });
  return saldo;
}

function calcCustoTotalAcumulado(imovel) {
  const aqs = imovel.precoAquisicao || 0;
  const entrada = imovel.financiamento?.entrada || 0;
  const { totalParcelas } = calcTotalJurosPagos(imovel);
  const lancamentos = (state.lancamentos || [])
    .filter(l => l.imovelId === imovel.id && l.tipo === 'saida')
    .reduce((s, l) => s + (l.valor || 0), 0);
  return aqs + totalParcelas + lancamentos;
}

function calcValorizacaoMinima(imovel, anos) {
  const custo = calcCustoTotalAcumulado(imovel);
  const vm = imovel.valorMercado || imovel.precoAquisicao || 0;
  if (!anos || anos <= 0 || !custo) return null;
  // Valorização anual necessária para que VF = custo total
  return (Math.pow(custo / vm, 1 / anos) - 1) * 100;
}

function calcPatrimonioLiquido() {
  return state.imoveis.reduce((s, im) => {
    const vm = im.valorMercado || im.precoAquisicao || 0;
    const saldo = calcSaldoAtual(im);
    return s + vm - saldo;
  }, 0);
}

function calcEndividamentoTotal() {
  const totalVM = state.imoveis.reduce((s, im) => s + (im.valorMercado || im.precoAquisicao || 0), 0);
  const totalDivida = state.imoveis.reduce((s, im) => s + calcSaldoAtual(im), 0);
  return totalVM > 0 ? (totalDivida / totalVM) * 100 : 0;
}

// ─── ROUTING ─────────────────────────────────────────────────────────────────
function showPage(page) {
  state.currentPage = page;
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  const pages = ['dashboard','imoveis','financiamento','fluxo','analise','config'];
  const idx = pages.indexOf(page);
  document.querySelectorAll('.nav-item')[idx]?.classList.add('active');

  const titles = {
    dashboard: 'Painel geral',
    imoveis: 'Imóveis cadastrados',
    financiamento: 'Financiamentos',
    fluxo: 'Fluxo de caixa',
    analise: 'Análise de viabilidade',
    config: 'Configurações'
  };
  document.getElementById('page-title').textContent = titles[page] || '';
  const renders = { dashboard: renderDashboard, imoveis: renderImoveis, financiamento: renderFinanciamento, fluxo: renderFluxo, analise: renderAnalise, config: renderConfig };
  (renders[page] || (() => {}))();
}

// ─── DASHBOARD ───────────────────────────────────────────────────────────────
function renderDashboard() {
  const actions = document.getElementById('topbar-actions');
  actions.innerHTML = `<button class="btn btn-primary btn-sm" onclick="showPage('imoveis')">+ Novo imóvel</button>`;

  const totalVM = state.imoveis.reduce((s, im) => s + (im.valorMercado || im.precoAquisicao || 0), 0);
  const totalDivida = state.imoveis.reduce((s, im) => s + calcSaldoAtual(im), 0);
  const pl = totalVM - totalDivida;
  const endiv = totalVM > 0 ? (totalDivida / totalVM) * 100 : 0;

  const mesAtual = new Date().toISOString().slice(0, 7);
  const saidasMes = (state.lancamentos || [])
    .filter(l => l.mes === mesAtual && l.tipo === 'saida')
    .reduce((s, l) => s + l.valor, 0);
  const entradasMes = (state.lancamentos || [])
    .filter(l => l.mes === mesAtual && l.tipo === 'entrada')
    .reduce((s, l) => s + l.valor, 0);

  let endivColor = 'color-success';
  let endivLabel = 'Baixo';
  if (endiv > 70) { endivColor = 'color-danger'; endivLabel = 'Alto'; }
  else if (endiv > 40) { endivColor = 'color-warn'; endivLabel = 'Moderado'; }

  const c = document.getElementById('content');
  c.innerHTML = `
    <div class="metrics-grid">
      <div class="metric-card">
        <div class="metric-label">Valor de mercado total</div>
        <div class="metric-value">${fmtBRL(totalVM)}</div>
        <div class="metric-sub">${state.imoveis.length} imóve${state.imoveis.length === 1 ? 'l' : 'is'}</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Saldo devedor total</div>
        <div class="metric-value metric-neg">${fmtBRL(totalDivida)}</div>
        <div class="metric-sub">financiamentos ativos</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Patrimônio líquido</div>
        <div class="metric-value metric-pos">${fmtBRL(pl)}</div>
        <div class="metric-sub">${fmtPct(totalVM > 0 ? (pl/totalVM)*100 : 0)} do total</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Nível de endividamento</div>
        <div class="metric-value ${endivColor}">${fmtPct(endiv)}</div>
        <div class="metric-sub ${endivColor}">${endivLabel}</div>
      </div>
    </div>

    <div class="metrics-grid">
      <div class="metric-card">
        <div class="metric-label">Saídas este mês</div>
        <div class="metric-value metric-neg">${fmtBRL(saidasMes)}</div>
        <div class="metric-sub">parcelas + despesas</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Entradas este mês</div>
        <div class="metric-value metric-pos">${fmtBRL(entradasMes)}</div>
        <div class="metric-sub">aluguéis e receitas</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Saldo do mês</div>
        <div class="metric-value ${entradasMes - saidasMes >= 0 ? 'metric-pos' : 'metric-neg'}">${fmtBRL(entradasMes - saidasMes)}</div>
        <div class="metric-sub">resultado mensal</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Custo acumulado total</div>
        <div class="metric-value">${fmtBRL(state.imoveis.reduce((s, im) => s + calcCustoTotalAcumulado(im), 0))}</div>
        <div class="metric-sub">aquisição + parcelas + despesas</div>
      </div>
    </div>

    ${state.imoveis.length === 0 ? `
      <div class="card"><div class="empty">
        <div class="empty-icon">🏠</div>
        <h3>Nenhum imóvel cadastrado</h3>
        <p>Cadastre o primeiro imóvel para começar a visualizar o patrimônio.</p>
        <button class="btn btn-primary" onclick="showPage('imoveis')">Cadastrar imóvel</button>
      </div></div>
    ` : `
      <div class="two-col">
        <div class="card">
          <div class="card-header"><span class="card-title">Endividamento por imóvel</span></div>
          ${state.imoveis.map(im => {
            const vm = im.valorMercado || im.precoAquisicao || 1;
            const sd = calcSaldoAtual(im);
            const pct = Math.min((sd / vm) * 100, 100);
            const cls = pct > 70 ? 'bar-danger' : pct > 40 ? 'bar-warn' : 'bar-ok';
            const tcls = pct > 70 ? 'color-danger' : pct > 40 ? 'color-warn' : 'color-success';
            return `<div class="chart-bar-row">
              <span class="chart-bar-label" title="${im.nome}">${im.nome}</span>
              <div class="chart-bar-track"><div class="chart-bar-fill ${cls}" style="width:${pct}%"></div></div>
              <span class="chart-bar-value ${tcls}">${fmtPct(pct, 0)}</span>
            </div>`;
          }).join('')}
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Valorização mínima p/ lucro (5 anos)</span></div>
          ${state.imoveis.map(im => {
            const val = calcValorizacaoMinima(im, 5);
            const cls = val === null ? '' : val > 12 ? 'color-danger' : val > 8 ? 'color-warn' : 'color-success';
            return `<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);">
              <span class="color-muted" style="font-size:13px">${im.nome}</span>
              <span class="fw-600 ${cls}" style="font-size:13px;font-family:var(--mono)">${val === null ? 'Quitado' : '+' + fmtPct(val)}/a.a.'}</span>
            </div>`;
          }).join('')}
        </div>
      </div>

      <div class="card mt-16">
        <div class="card-header"><span class="card-title">Resumo dos imóveis</span></div>
        <div class="table-wrap">
          <table>
            <thead><tr>
              <th>Empreendimento</th>
              <th class="td-right">Vl. mercado</th>
              <th class="td-right">Saldo devedor</th>
              <th class="td-right">Parcela/mês</th>
              <th class="td-right">Juros</th>
              <th>Status</th>
            </tr></thead>
            <tbody>
              ${state.imoveis.map(im => {
                const sd = calcSaldoAtual(im);
                const amort = gerarAmortizacao(im);
                const parcela = amort[0]?.parcela || 0;
                const taxa = im.financiamento?.taxaJurosAnual || 0;
                const tag = sd === 0 ? '<span class="tag tag-ok">Quitado</span>'
                  : taxa > 10 ? '<span class="tag tag-danger">Alto custo</span>'
                  : '<span class="tag tag-warn">Financiado</span>';
                return `<tr style="cursor:pointer" onclick="showPage('imoveis')">
                  <td><div style="font-weight:500">${im.nome}</div><div style="font-size:11px;color:var(--text3)">${im.tipo || ''} · Adq. ${fmtDate(im.dataAquisicao)}</div></td>
                  <td class="td-right td-mono">${fmtBRL(im.valorMercado || im.precoAquisicao)}</td>
                  <td class="td-right td-mono ${sd > 0 ? 'color-danger' : 'color-success'}">${sd > 0 ? fmtBRL(sd) : '—'}</td>
                  <td class="td-right td-mono">${parcela > 0 ? fmtBRL(parcela) : '—'}</td>
                  <td class="td-right td-mono">${taxa > 0 ? fmtPct(taxa) + ' a.a.' : '—'}</td>
                  <td>${tag}</td>
                </tr>`;
              }).join('')}
            </tbody>
          </table>
        </div>
      </div>
    `}
  `;
}

// ─── IMÓVEIS ─────────────────────────────────────────────────────────────────
function renderImoveis() {
  const actions = document.getElementById('topbar-actions');
  actions.innerHTML = `<button class="btn btn-primary btn-sm" onclick="openModalImovel()">+ Cadastrar imóvel</button>`;

  const c = document.getElementById('content');
  if (state.imoveis.length === 0) {
    c.innerHTML = `<div class="card"><div class="empty">
      <div class="empty-icon">🏠</div>
      <h3>Nenhum imóvel cadastrado ainda</h3>
      <p>Clique em "Cadastrar imóvel" para começar.</p>
      <button class="btn btn-primary" onclick="openModalImovel()">+ Cadastrar imóvel</button>
    </div></div>`;
    return;
  }

  c.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
      ${state.imoveis.map(im => renderCardImovel(im)).join('')}
    </div>`;
}

function renderCardImovel(im) {
  const sd = calcSaldoAtual(im);
  const vm = im.valorMercado || im.precoAquisicao || 0;
  const pl = vm - sd;
  const pctDivida = vm > 0 ? (sd / vm) * 100 : 0;
  const amort = gerarAmortizacao(im);
  const parcela = amort[0]?.parcela || 0;
  const custo = calcCustoTotalAcumulado(im);
  const val5 = calcValorizacaoMinima(im, 5);

  return `<div class="card" style="display:flex;flex-direction:column;gap:14px">
    <div style="display:flex;justify-content:space-between;align-items:flex-start">
      <div>
        <div style="font-size:15px;font-weight:600;color:var(--text)">${im.nome}</div>
        <div style="font-size:12px;color:var(--text3);margin-top:2px">${im.tipo || 'Não informado'} · ${im.empreendimento || ''}</div>
      </div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-ghost btn-sm" onclick="openModalImovel('${im.id}')">Editar</button>
        <button class="btn btn-danger btn-sm" onclick="deletarImovel('${im.id}')">Excluir</button>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <div><div class="metric-label">Valor de mercado</div><div style="font-size:15px;font-weight:600">${fmtBRL(vm)}</div></div>
      <div><div class="metric-label">Saldo devedor</div><div style="font-size:15px;font-weight:600;color:${sd > 0 ? 'var(--danger)' : 'var(--success)'}">${sd > 0 ? fmtBRL(sd) : 'Quitado'}</div></div>
      <div><div class="metric-label">Patrimônio líquido</div><div style="font-size:15px;font-weight:600;color:var(--success)">${fmtBRL(pl)}</div></div>
      <div><div class="metric-label">Parcela mensal</div><div style="font-size:15px;font-weight:600">${parcela > 0 ? fmtBRL(parcela) : '—'}</div></div>
    </div>
    ${pctDivida > 0 ? `
    <div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:4px">
        <span>Endividamento</span><span>${fmtPct(pctDivida)}</span>
      </div>
      <div class="bar-wrap"><div class="bar-fill ${pctDivida > 70 ? 'bar-danger' : pctDivida > 40 ? 'bar-warn' : 'bar-ok'}" style="width:${pctDivida}%"></div></div>
    </div>` : ''}
    <div style="display:flex;justify-content:space-between;font-size:12px;padding-top:8px;border-top:1px solid var(--border)">
      <span class="color-muted">Custo acumulado: <strong>${fmtBRL(custo)}</strong></span>
      <span class="color-muted">Val. mín. (5a): <strong class="${val5 && val5 > 12 ? 'color-danger' : val5 && val5 > 8 ? 'color-warn' : 'color-success'}">${val5 !== null ? '+' + fmtPct(val5) + '/a.a.' : 'Quitado'}</strong></span>
    </div>
    <button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center" onclick="showPage('financiamento');filterImovel='${im.id}'">Ver financiamento →</button>
  </div>`;
}

